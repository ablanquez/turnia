# Dependencias y artefactos de build — nunca en main (lo compilado vive en la rama produccion)
node_modules/
dist/
.deploy-produccion/

# Docs: se VERSIONAN POR DEFECTO. El estado por defecto es conservar; olvidar es ruido visible en
# git status, no pérdida silenciosa (invierte el modo de fallo del viejo /docs/*.md + lista blanca).
# Lo efímero va explícito a docs/borrador/ (su contenido se ignora; el .gitkeep deja la carpeta a la
# vista para que la convención exista).
/docs/borrador/*
!/docs/borrador/.gitkeep

# Sistema
.DS_Store
*.log
