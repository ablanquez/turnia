#!/usr/bin/env bash
#
# La bitácora es obligatoria en cada `fix:`. Si falta, NO se bloquea a secas: se AUTOGENERA el
# esqueleto (todo NO CONSTA) y se deja en el stage, para que cumplir sea fácil, no solo incumplir
# difícil. Y si el commit toca la paleta/tokens, el contraste de color tiene que pasar.
#
# Se activa con:  git config core.hooksPath .githooks
#
set -u

MSG_FILE="$1"
SUBJECT="$(head -n1 "$MSG_FILE")"
BITACORA="docs/BITACORA.md"

es_fix() { printf '%s' "$SUBJECT" | grep -qE '^fix(\(.+\))?!?:'; }
esta_en_stage() { git diff --cached --name-only | grep -qx "$1"; }

# ── 1. Todo fix: lleva su entrada de bitácora ───────────────────────────────────────────
if es_fix && ! esta_en_stage "$BITACORA"; then
    FECHA="$(date +%F)"
    TITULO="$(printf '%s' "$SUBJECT" | sed -E 's/^fix(\(.+\))?!?:[[:space:]]*//')"

    {
        printf '\n## [%s] — %s\n' "$FECHA" "$TITULO"
        printf '**Categoría:** NO CONSTA\n'
        printf '**Síntoma:** NO CONSTA\n'
        printf '**Qué se probó y DIO VERDE mientras el fallo estaba vivo:** NO CONSTA\n'
        printf '**Causa raíz:** NO CONSTA\n'
        printf '**Cómo se cazó:** NO CONSTA\n'
        printf '**Arreglo aplicado:** NO CONSTA\n'
        printf '**Commit:** (este commit)\n'
        printf '**Ley que sale de aquí:** NO CONSTA\n'
        printf '**Traza:** NO CONSTA\n'
    } >> "$BITACORA"

    git add "$BITACORA"

    {
        echo '───────────────────────────────────────────────────────────────'
        echo '⚠️  fix: sin entrada de bitácora.'
        echo "    He AUTOGENERADO el esqueleto en $BITACORA (todo NO CONSTA) y lo he añadido al stage."
        echo '    Rellena lo que sepas (el ⭐ es el dato perecedero; si no hubo verde que mintiera,'
        echo '    déjalo en NO CONSTA sin paja) y vuelve a commitear.'
        echo '───────────────────────────────────────────────────────────────'
    } >&2
    exit 1
fi

# ── 2. Gobernanza del color ──────────────────────────────────────────────────────────────
CAMBIOS="$(git diff --cached --name-only)"

# 2a. Ningún color suelto en un .vue/.css tocado.
if printf '%s\n' "$CAMBIOS" | grep -qE '\.(vue|css)$'; then
    if [ -f src/estilo/sin-hex.check.mjs ] && ! node src/estilo/sin-hex.check.mjs >&2; then
        echo '⚠️  Hay un color suelto fuera de la fuente. No se cierra el commit.' >&2
        exit 1
    fi
fi

# 2b. Si toca la paleta/tokens, el color no puede colisionar entre familias.
if printf '%s\n' "$CAMBIOS" | grep -qE 'src/datos/paleta\.js|src/estilo/tokens\.css'; then
    if [ -f src/estilo/contraste.check.mjs ] && ! node src/estilo/contraste.check.mjs >&2; then
        echo '⚠️  contraste.check FALLÓ: un color colisiona con otra familia. No se cierra el commit.' >&2
        exit 1
    fi
fi

# ── 3. La lógica pasa sus tests ──────────────────────────────────────────────────────────
# Disparador: CUALQUIER .js/.mjs tocado, NO una lista blanca de rutas. Una lista de rutas es la
# misma trampa que el .gitignore que escondió la auditoría: hay que acordarse de ampliarla, y el
# día que nace lógica en una carpeta nueva (el motor, un helper, useArrastre.js) entra en silencio
# y en verde. Fail-closed: el fichero nuevo queda cubierto sin tocar el hook. Discrimina de verdad:
# un commit de solo .md/.vue/.css no arrastra la suite (los .vue ya tienen su propia red: color +
# geometría + ojo). Cubre vite.config.js a propósito: gobierna el propio glob de test, y si se
# rompe, `vitest run` no encuentra NINGÚN test y sale 1 → aquí se trata como fallo (0 casos ≠ 0
# fallos). Ese exit 1 en vacío es una guardia BUSCADA, no un incordio: que nadie lo "arregle".
if printf '%s\n' "$CAMBIOS" | grep -qE '\.(js|mjs)$'; then
    echo '· toca lógica (.js/.mjs) → corriendo la suite de tests…' >&2
    if ! npm test --silent >&2; then
        echo '⚠️  Los tests de lógica NO pasan (o el glob no encontró NINGUNO: 0 casos ≠ 0 fallos).' >&2
        echo '    No se cierra el commit.' >&2
        exit 1
    fi
fi

exit 0
